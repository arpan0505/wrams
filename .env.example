# ============================================================
# WRAMS Modular Service — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# On Ubuntu server: /opt/services/wrams/.env
# ============================================================

# --- Service Profile ---
# Which service profile to load. Options: "wrams"
# This controls filter cascades, table names, UI labels, etc.
SERVICE_PROFILE=wrams

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=5001
DB_NAME=wrams
DB_USER=postgres
DB_PASSWORD=Passw0rd

# --- Service Ports ---
VISION_PLAYER_PORT=8000
ASSET_FILTER_PORT=8001

# --- External Java API ---
JAVA_API_HOST=localhost
JAVA_API_PORT=49001

# --- Storage ---
# Absolute path recommended for Ubuntu. Relative path works for dev.
FRAMES_STORAGE_DIR=frames_storage_1

# --- Public URLs (used by frontend for cross-service navigation) ---
# In production behind nginx, these would be like:
#   PUBLIC_VISION_PLAYER_URL=https://yourdomain.com/vision
#   PUBLIC_ASSET_FILTER_URL=https://yourdomain.com/filter
PUBLIC_VISION_PLAYER_URL=http://localhost:8000
PUBLIC_ASSET_FILTER_URL=http://localhost:8001
PUBLIC_UPLOAD_URL=/api/frames/batch

# --- Server Bind ---
# Use 0.0.0.0 for production, 127.0.0.1 for local dev
SERVER_HOST=0.0.0.0
